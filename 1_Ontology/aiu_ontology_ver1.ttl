    skos:prefLabel "Creating visually appealing presentations using AI-driven design suggestions."@en ;
    skos:topConceptOf aiu:CommercialAITypeScheme ; skos:inScheme aiu:CommercialAITypeScheme .

aiu:CAI_DataViz a skos:Concept, owl:NamedIndividual ;
    skos:prefLabel "Creating visual representations of data sets for reports and presentations using AI."@en ;
    skos:topConceptOf aiu:CommercialAITypeScheme ; skos:inScheme aiu:CommercialAITypeScheme .

aiu:CAI_NewsCurate a skos:Concept, owl:NamedIndividual ;
    skos:prefLabel "Curating news articles and updates based on user preferences using AI."@en ;
    skos:topConceptOf aiu:CommercialAITypeScheme ; skos:inScheme aiu:CommercialAITypeScheme .

aiu:CAI_TravelRoute a skos:Concept, owl:NamedIndividual ;
    skos:prefLabel "Planning travel routes using AI-driven map applications."@en ;
    skos:topConceptOf aiu:CommercialAITypeScheme ; skos:inScheme aiu:CommercialAITypeScheme .

aiu:CAI_TravelBook a skos:Concept, owl:NamedIndividual ;
    skos:prefLabel "Finding and booking travel accommodations using AI-powered platforms."@en ;
    skos:topConceptOf aiu:CommercialAITypeScheme ; skos:inScheme aiu:CommercialAITypeScheme .

aiu:CAI_FaceRecog a skos:Concept, owl:NamedIndividual ;
    skos:prefLabel "Unlocking smartphones or other devices without the need for passwords or PINs using AI-based facial recognition technology."@en ;
    skos:topConceptOf aiu:CommercialAITypeScheme ; skos:inScheme aiu:CommercialAITypeScheme .

aiu:CAI_NoneOfTheAbove a skos:Concept, owl:NamedIndividual ;
    skos:prefLabel "None of the Above"@en ;
    skos:definition "The AI use case is NOT implemented solely with the listed commercial off-the-shelf products. This is the gate concept: records with this value require the full set of additional inventory fields."@en ;
    skos:topConceptOf aiu:CommercialAITypeScheme ; skos:inScheme aiu:CommercialAITypeScheme .


#################################################################
# E. Organizations and roles
# Fix O-1, O-4: updated CCO v2.0 IRIs for Organization (ont00001180)
#################################################################

aiu:Agency a owl:Class ;
    rdfs:label "Agency" ;
    rdfs:subClassOf cco:ont00001180 ;  # CCO Organization, v2.0 IRI
    rdfs:comment "A federal department or independent agency responsible for one or more AI use cases in the inventory." .

aiu:Bureau a owl:Class ;
    rdfs:label "Bureau or component" ;
    rdfs:subClassOf cco:ont00001180 ;  # CCO Organization, v2.0 IRI
    rdfs:comment "An organizational unit (bureau, component, office) within an agency." .

aiu:SystemOwnerRole a owl:Class ;
    rdfs:label "System owner role" ;
    rdfs:subClassOf bfo:0000023 ;  # BFO: role
    rdfs:comment "A role borne by an agent responsible for the overall management and accountability of an AI system or use case." .

aiu:DeveloperRole a owl:Class ;
    rdfs:label "Developer role" ;
    rdfs:subClassOf bfo:0000023 ;
    rdfs:comment "A role borne by an agent responsible for designing, implementing, or configuring the AI system used in a use case." .

aiu:OperatorRole a owl:Class ;
    rdfs:label "Operator role" ;
    rdfs:subClassOf bfo:0000023 ;
    rdfs:comment "A role borne by an agent who operates or oversees the AI use case in day-to-day service delivery." .

aiu:OversightRole a owl:Class ;
    rdfs:label "Oversight role" ;
    rdfs:subClassOf bfo:0000023 ;
    rdfs:comment "A role borne by an agent responsible for oversight, compliance, or governance of an AI use case (e.g., CIO, SAOP, CAIO, risk committee)." .


#################################################################
# F. Systems, data, and outputs
# Fix O-1: updated CCO v2.0 IRI for Artifact (ont00000995)
#################################################################

aiu:AISystem a owl:Class ;
    rdfs:label "AI system" ;
    rdfs:subClassOf cco:ont00000995 ;  # CCO Artifact, v2.0 IRI
    rdfs:comment "A technical artifact (software and associated services) that implements one or more AI functions and participates in AI use case processes." .

aiu:AIFunction a owl:Class ;
    rdfs:label "AI function" ;
    rdfs:subClassOf bfo:0000034 ;  # BFO: function
    rdfs:comment "A function borne by an AI system, such as classification, recommendation, anomaly detection, or generation." .

aiu:Dataset a owl:Class ;
    rdfs:label "Dataset" ;
    rdfs:subClassOf iao:0000100 ;  # IAO: dataset
    rdfs:comment "A dataset used to train, fine-tune, evaluate, or operate an AI system in a use case, including agency-owned and external data." .

aiu:AIOutputArtifact a owl:Class ;
    rdfs:label "AI output artifact" ;
    rdfs:subClassOf iao:0000005 ;  # IAO: data item
    rdfs:comment "An information content entity that is the output of an AI use case process (e.g., risk score, classification, decision recommendation)." .


#################################################################
# G. Risk, impact, and governance
# Fix O-2: AIImpactAssessmentProcess now subClassOf cco:ont00000228
# Fix O-3: GovernancePolicy now uses cco:ont00000965
#################################################################

aiu:RiskRole a owl:Class ;
    rdfs:label "Risk role" ;
    rdfs:subClassOf bfo:0000023 ;  # BFO: role
    rdfs:comment "A role borne by an AI use case process, system, or configuration that may be realized in an adverse impact on rights, safety, privacy, or other protected interests." .

aiu:RightsImpactRiskRole a owl:Class ;
    rdfs:label "Rights-impacting risk role" ;
    rdfs:subClassOf aiu:RiskRole ;
    rdfs:comment "A risk role indicating that the use of AI in a use case could significantly affect civil or human rights." .

aiu:SafetyImpactRiskRole a owl:Class ;
    rdfs:label "Safety-impacting risk role" ;
    rdfs:subClassOf aiu:RiskRole ;
    rdfs:comment "A risk role indicating that the use of AI in a use case could significantly affect safety, health, or bodily integrity." .

aiu:PIIRiskRole a owl:Class ;
    rdfs:label "PII-related risk role" ;
    rdfs:subClassOf aiu:RiskRole ;
    rdfs:comment "A risk role indicating that the use of AI in a use case involves personally identifiable information (PII) and associated privacy risks." .

aiu:RiskAssessmentDocument a owl:Class ;
    rdfs:label "Risk assessment document" ;
    rdfs:subClassOf iao:0000310 ;  # IAO: document
    rdfs:comment "A document that describes risks, impacts, and mitigations associated with an AI use case (e.g., AI impact assessment, privacy assessment)." .

aiu:AIImpactAssessmentProcess a owl:Class ;
    rdfs:label "AI impact assessment process" ;
    rdfs:subClassOf cco:ont00000228 ;  # Fix O-2: CCO Planned Act, v2.0 IRI
    rdfs:comment "A planned act that evaluates the potential and actual impacts of an AI use case on rights, safety, equity, or other protected interests." .

aiu:GovernancePolicy a owl:Class ;
    rdfs:label "Governance policy" ;
    rdfs:subClassOf cco:ont00000965 ;  # Fix O-3: CCO Directive ICE, v2.0 IRI
    rdfs:comment "A directive information content entity (e.g., policy, guidance) that prescribes governance, risk management, or oversight requirements for AI use cases." .


#################################################################
# H. Time and provenance
# Fix O-6: TimeInstant now subClassOf bfo:0000203 (temporal instant, BFO 2020)
#################################################################

aiu:TimeInstant a owl:Class ;
    rdfs:label "Time instant" ;
    rdfs:subClassOf bfo:0000203 ;  # Fix O-6: BFO temporal instant (BFO 2020), not 0000008
    rdfs:comment "A temporal instant (single point in time) used to represent key dates in the lifecycle of an AI use case (e.g., initiated, implemented, retired)." .


#################################################################
# I. Object properties
#################################################################

# Reused RO/BFO relations (for reference; IRIs come from RO/BFO):
#   ro:has_part / bfo:0000050 / bfo:0000051
#   bfo:0000052 inheres in / bfo:0000053 bearer of
#   bfo:0000054 realized by / bfo:0000055 realizes
#   ro:0000056 participates in / ro:0000057 has participant

### Record ↔ Plan/Process/Snapshot

aiu:describesPlan a owl:ObjectProperty ;
    rdfs:label "describes plan" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range aiu:AIUseCasePlan ;
    rdfs:comment "Relates an inventory record to the AI use case plan it describes." .

aiu:describesProcess a owl:ObjectProperty ;
    rdfs:label "describes process" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range aiu:AIUseCaseProcess ;
    rdfs:comment "Relates an inventory record to the AI use case process it describes." .

aiu:partOfInventory a owl:ObjectProperty ;
    rdfs:label "part of inventory" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range aiu:InventorySnapshot ;
    rdfs:comment "Relates a use case record to the annual inventory snapshot it belongs to." .

### Agency and bureau

aiu:hasAgency a owl:ObjectProperty ;
    rdfs:label "has agency" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range aiu:Agency ;
    rdfs:comment "Relates a use case record to the agency responsible for the use case." .

aiu:hasBureau a owl:ObjectProperty ;
    rdfs:label "has bureau or component" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range aiu:Bureau ;
    rdfs:comment "Relates a use case record to the bureau or component within an agency." .

### Plan ↔ Process / Goals

aiu:hasPlannedProcess a owl:ObjectProperty ;
    rdfs:label "has planned process" ;
    rdfs:domain aiu:AIUseCasePlan ; rdfs:range aiu:AIUseCaseProcess ;
    rdfs:comment "Relates a plan specification to the AI use case process it prescribes." .

aiu:hasBusinessGoal a owl:ObjectProperty ;
    rdfs:label "has business goal" ;
    rdfs:domain aiu:AIUseCasePlan ; rdfs:range aiu:BusinessGoalConcept ;
    rdfs:comment "Relates an AI use case plan to a business goal concept from the business-goal taxonomy that the plan aims to realize." .

### Process ↔ categorized attributes (replaced xsd:string data props with SKOS ObjectProperties)

aiu:hasTopicArea a owl:ObjectProperty ;
    rdfs:label "has topic area" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its topic area concept from the TopicAreaScheme vocabulary (field 8_topic_area)." .

aiu:hasDevelopmentStage a owl:ObjectProperty ;
    rdfs:label "has development stage" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its current SDLC stage concept from the DevStageScheme vocabulary (field 16_dev_stage)." .

aiu:hasImpactType a owl:ObjectProperty ;
    rdfs:label "has impact type" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its impact classification concept from the ImpactTypeScheme vocabulary (field 17_impact_type)." .

aiu:usesDemographicFeature a owl:ObjectProperty ;
    rdfs:label "uses demographic feature" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to demographic feature types explicitly used in its model/data (field 35_demo_features)." .

aiu:hasCommercialAIType a owl:ObjectProperty ;
    rdfs:label "has commercial AI type" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range skos:Concept ;
    rdfs:comment "Relates a use case record to its commercial AI tool classification from CommercialAITypeScheme (field 10_commercial_ai). Use aiu:CAI_NoneOfTheAbove for custom/non-COTS AI." .

aiu:hasDevelopmentMethod a owl:ObjectProperty ;
    rdfs:label "has development method" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its development method concept from DevMethodScheme (field 22_dev_method)." .

aiu:hasCodeAccess a owl:ObjectProperty ;
    rdfs:label "has code access type" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its code access classification from CodeAccessScheme (field 38_code_access)." .

aiu:hasMonitoringMaturity a owl:ObjectProperty ;
    rdfs:label "has monitoring maturity" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its post-deployment monitoring maturity level from MonitoringMaturityScheme (field 56_monitor_postdeploy)." .

aiu:hasDataDocLevel a owl:ObjectProperty ;
    rdfs:label "has data documentation level" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its training data documentation level from DataDocLevelScheme (field 34_data_docs)." .

aiu:hasTestingLevel a owl:ObjectProperty ;
    rdfs:label "has real-world testing level" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its real-world testing level from TestingLevelScheme (field 53_real_world_testing)." .

aiu:hasInternalReviewLevel a owl:ObjectProperty ;
    rdfs:label "has internal review level" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to its internal model documentation review level from InternalReviewScheme (field 50_internal_review)." .

aiu:supportsHISP a owl:ObjectProperty ;
    rdfs:label "supports HISP" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range skos:Concept ;
    rdfs:comment "Relates an AI use case process to the specific HISP it supports from HISPScheme (fields 24_hisp_support / 25_hisp_name)." .

### Process ↔ technical components

aiu:usesAISystem a owl:ObjectProperty ;
    rdfs:label "uses AI system" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:AISystem ;
    rdfs:comment "Relates an AI use case process to the AI system that participates in it." .

aiu:hasInputDataset a owl:ObjectProperty ;
    rdfs:label "has input dataset" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:Dataset ;
    rdfs:comment "Relates an AI use case process to a dataset used as input." .

aiu:hasOutputArtifact a owl:ObjectProperty ;
    rdfs:label "has output artifact" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:AIOutputArtifact ;
    rdfs:comment "Relates an AI use case process to an information artifact it produces." .

### Risk and governance

aiu:hasRiskRole a owl:ObjectProperty ;
    rdfs:label "has risk role" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:RiskRole ;
    rdfs:comment "Relates an AI use case process to a risk role that inheres in it." .

aiu:assessedBy a owl:ObjectProperty ;
    rdfs:label "assessed by" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:AIImpactAssessmentProcess ;
    rdfs:comment "Relates an AI use case process to an impact assessment process that evaluates it." .

aiu:hasAssessmentOutput a owl:ObjectProperty ;
    rdfs:label "has assessment output" ;
    rdfs:domain aiu:AIImpactAssessmentProcess ; rdfs:range aiu:RiskAssessmentDocument ;
    rdfs:comment "Relates an impact assessment process to the risk assessment document it produces." .

aiu:governedBy a owl:ObjectProperty ;
    rdfs:label "governed by" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:GovernancePolicy ;
    rdfs:comment "Relates an AI use case process to a governance policy that prescribes constraints, controls, or procedures for it." .

### Temporal

aiu:hasInitiationTime a owl:ObjectProperty ;
    rdfs:label "has initiation time" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:TimeInstant ;
    rdfs:comment "Time at which the AI use case purpose and high-level requirements were first defined (field 18_date_initiated)." .

aiu:hasAcqDevTime a owl:ObjectProperty ;
    rdfs:label "has acquisition/development start time" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:TimeInstant ;
    rdfs:comment "Time at which acquisition and/or development of the AI system first began (field 19_date_acq_dev_began)." .

aiu:hasImplementationTime a owl:ObjectProperty ;
    rdfs:label "has implementation time" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:TimeInstant ;
    rdfs:comment "Time at which the use case was fully implemented and deployed (field 20_date_implemented)." .

aiu:hasRetirementTime a owl:ObjectProperty ;
    rdfs:label "has retirement time" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range aiu:TimeInstant ;
    rdfs:comment "Time at which the use case was retired or began retirement (field 21_date_retired)." .

### Cross-year record continuity
# Fix O-15

aiu:possibleDuplicateOf a owl:ObjectProperty ;
    rdfs:label "possible duplicate of" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range aiu:UseCaseRecord ;
    owl:SymmetricProperty true ;
    rdfs:comment "Relates two use case records suspected or determined to represent the same underlying AI use case (for duplication analysis and entity resolution)." .

aiu:continuesFrom a owl:ObjectProperty ;
    rdfs:label "continues from" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range aiu:UseCaseRecord ;
    rdfs:comment "Relates a use case record in a later inventory year to the corresponding record in an earlier year, confirming cross-year identity of the same use case." .


#################################################################
# J. Data properties
# Note: string-valued properties stageOfDevelopment and rightsImpactCategory
# from the earlier draft were removed entirely; their semantics are now
# captured by the object properties hasDevStage and hasImpactType (section I).
#################################################################

aiu:inventoryYear a owl:DatatypeProperty ;
    rdfs:label "inventory year" ;
    rdfs:domain aiu:InventorySnapshot ; rdfs:range xsd:gYear ;
    rdfs:comment "The reporting year of the Federal AI Use Case Inventory (e.g., 2023, 2024)." .

aiu:useCaseName a owl:DatatypeProperty ;
    rdfs:label "use case name" ;
    rdfs:domain aiu:UseCaseRecord ; rdfs:range xsd:string ;
    rdfs:comment "Title of the AI use case as reported in the inventory (field 2_use_case_name)." .

aiu:purposeBenefitsText a owl:DatatypeProperty ;
    rdfs:label "purpose and benefits text" ;
    rdfs:domain aiu:AIUseCasePlan ; rdfs:range xsd:string ;
    rdfs:comment "Free-text description of the AI's intended purpose, problem solved, and expected benefits (field 11_purpose_benefits). Primary source for business goal classification." .

aiu:outputsText a owl:DatatypeProperty ;
    rdfs:label "AI system outputs text" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range xsd:string ;
    rdfs:comment "Free-text description of what the AI system outputs (field 12_outputs). Secondary source for business goal classification." .

aiu:agencyDataDescription a owl:DatatypeProperty ;
    rdfs:label "agency data description" ;
    rdfs:domain aiu:Dataset ; rdfs:range xsd:string ;
    rdfs:comment "General description of training, fine-tuning, and evaluation data (field 33_agency_data)." .

aiu:keyRisksText a owl:DatatypeProperty ;
    rdfs:label "key risks text" ;
    rdfs:domain aiu:RiskAssessmentDocument ; rdfs:range xsd:string ;
    rdfs:comment "Free-text identification of reasonably foreseeable risks (field 54_key_risks)." .

aiu:systemName a owl:DatatypeProperty ;
    rdfs:label "system name" ;
    rdfs:domain aiu:AISystem ; rdfs:range xsd:string ;
    rdfs:comment "Name of the AI system according to the ATO (field 41_system_name)." .

aiu:hasATO a owl:DatatypeProperty ;
    rdfs:label "has ATO" ;
    rdfs:domain aiu:AISystem ; rdfs:range xsd:boolean ;
    rdfs:comment "Whether the AI system has an Authority to Operate (field 40_has_ato)." .

aiu:usesPII a owl:DatatypeProperty ;
    rdfs:label "uses PII" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range xsd:boolean ;
    rdfs:comment "Whether the AI use case involves personally identifiable information (field 29_contains_pii)." .

aiu:saopReviewed a owl:DatatypeProperty ;
    rdfs:label "SAOP reviewed" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range xsd:boolean ;
    rdfs:comment "Whether the SAOP has assessed privacy risks for this use case (field 30_saop_review)." .

aiu:customCodePresent a owl:DatatypeProperty ;
    rdfs:label "custom-developed code present" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range xsd:boolean ;
    rdfs:comment "Whether the use case includes custom-developed code (field 37_custom_code)." .

aiu:openSourceCodeURL a owl:DatatypeProperty ;
    rdfs:label "open-source code URL" ;
    rdfs:domain aiu:AISystem ; rdfs:range xsd:anyURI ;
    rdfs:comment "URL to publicly available source code (field 39_code_link)." .

aiu:autonomousImpact a owl:DatatypeProperty ;
    rdfs:label "autonomous impact decisions" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range xsd:boolean ;
    rdfs:comment "Whether the AI can carry out individual core decisions affecting rights/safety without direct human involvement (field 57_autonomous_impact)." .

aiu:hasAppealProcess a owl:DatatypeProperty ;
    rdfs:label "has appeal process" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range xsd:boolean ;
    rdfs:comment "Whether an appeal/escalation fallback process exists for AI decisions (field 65_appeal_process)." .

aiu:hasOptOut a owl:DatatypeProperty ;
    rdfs:label "has opt-out mechanism" ;
    rdfs:domain aiu:AIUseCaseProcess ; rdfs:range xsd:boolean ;
    rdfs:comment "Whether an opt-out mechanism has been established (field 67_opt_out)." .
