@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

@prefix bfo:  <http://purl.obolibrary.org/obo/BFO_> .
@prefix ro:   <http://purl.obolibrary.org/obo/RO_> .
@prefix iao:  <http://purl.obolibrary.org/obo/IAO_> .
@prefix cco:  <https://www.commoncoreontologies.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

@prefix aiu:  <https://example.org/ai-usecase-ontology#> .

#################################################################
# Ontology header
# Fix O-1: CCO import IRI updated to v2.0
# Fix O-5: BFO import IRI updated to BFO 2020 versioned IRI
#################################################################

aiu:
    a owl:Ontology ;
    rdfs:label "AI Use Case Ontology (BFO-aligned)" ;
    rdfs:comment "Ontology for modeling U.S. Federal AI use cases, goals, risks, and governance, aligned with BFO 2020, RO, IAO, and CCO v2.0." ;
    owl:versionInfo "2.0" ;
    owl:imports
        <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> ,
        <http://purl.obolibrary.org/obo/ro.owl> ,
        <http://purl.obolibrary.org/obo/iao.owl> ,
        <https://www.commoncoreontologies.org/AllCoreOntology> ,
        <http://www.w3.org/ns/prov-o#> ,
        <http://www.w3.org/2004/02/skos/core> .

# CCO v2.0 class IRIs referenced:
#   Planned Act (IntentionalAct)          cco:ont00000228
#   Directive Information Content Entity  cco:ont00000965
#   Objective                             cco:ont00000476
#   Organization                          cco:ont00001180
#   Artifact                              cco:ont00000995
#   InformationContentEntity              cco:ont00000958


#################################################################
# A. Core classes — use case record, plan, process
#################################################################

### Use case record (one inventory row = one information artifact)

aiu:UseCaseRecord a owl:Class ;
    rdfs:label "Use case record" ;
    rdfs:subClassOf iao:0000310 ,     # IAO: document
                    prov:Entity ,     # Fix O-14: PROV-O integration
                    [ a owl:Restriction ;
                      owl:onProperty prov:wasAttributedTo ;
                      owl:someValuesFrom aiu:Agency ] ,
                    [ a owl:Restriction ;
                      owl:onProperty prov:generatedAtTime ;
                      owl:someValuesFrom xsd:dateTime ] ;
    rdfs:comment "An information artifact corresponding to a single row in the OMB Federal AI Use Case Inventory for a given year. Each record is attributed to the reporting Agency (prov:wasAttributedTo) and timestamped to the inventory reporting year (prov:generatedAtTime)." .

### AI use case plan (prescriptive specification of intent)

aiu:AIUseCasePlan a owl:Class ;
    rdfs:label "AI use case plan" ;
    rdfs:subClassOf iao:0000104 ,                # IAO: plan specification
                    cco:ont00000965 ;            # Fix O-3: CCO Directive ICE, v2.0 IRI
    rdfs:comment "A plan specification that prescribes the intended AI-enabled process for a use case, including objectives, scope, and context." .

### AI use case process (the real-world deployed process)

aiu:AIUseCaseProcess a owl:Class ;
    rdfs:label "AI use case process" ;
    rdfs:subClassOf cco:ont00000228 ;  # Fix O-2: CCO Planned Act (IntentionalAct), v2.0 IRI
    rdfs:comment "A planned act in which an AI system is deployed and operated to achieve one or more business goals within an agency context." .

### Inventory snapshot (the annual inventory as a named entity)
# Fix O-9: new class for cross-year analysis and named graph anchoring

aiu:InventorySnapshot a owl:Class ;
    rdfs:label "Inventory snapshot" ;
    rdfs:subClassOf iao:0000310 ;      # IAO: document
    rdfs:comment "An information artifact representing the complete Federal AI Use Case Inventory for a specific reporting year (e.g., 2023, 2024). Used to anchor use case records to a named graph and support cross-year provenance." .


#################################################################
# B. Business goal OWL class
# Fix O-4: separated from skos:Concept; SKOS concepts are NamedIndividuals (section C)
#################################################################

aiu:BusinessGoalConcept a owl:Class ;
    rdfs:label "Business goal concept" ;
    rdfs:subClassOf cco:ont00000476 ;  # Fix O-4: CCO Objective, v2.0 IRI
    rdfs:comment "An objective that prescribes a projected state an agency intends to achieve through an AI use case. Individuals of this class are also declared as owl:NamedIndividual skos:Concept members of aiu:BusinessGoalTaxonomy." .


#################################################################
# C. Business goal SKOS taxonomy
# Fix O-4, O-8: ConceptScheme and Concept instances as owl:NamedIndividual
# altLabels (keyword cues for NLP classification) should be derived
# from the lookup-fields in taxonomy_bizGoals.md and added here.
#################################################################

aiu:BusinessGoalTaxonomy a skos:ConceptScheme, owl:NamedIndividual ;
    skos:prefLabel "Federal AI Use Case Business Goal Taxonomy"@en ;
    skos:definition "A controlled vocabulary of business goals organized into 10 clusters with ~40 sub-goals, used to classify U.S. Federal AI use cases."@en ;
    dct:creator "MetaGraph project" .

### Cluster 1: Strategic and Business Model Goals

aiu:BG_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Strategic and Business Model Goals"@en ;
    skos:definition "Goals related to mission direction, strategic fit, business model design, and scaling strategy under uncertainty."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_1_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Direction, ambition, and coherence"@en ;
    skos:definition "Define a clear, credible mission and align purpose, strategy, and goals across the organization."@en ;
    skos:broader aiu:BG_1 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_1_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Strategic fit, market choices, and portfolio moves"@en ;
    skos:definition "Enter and expand in domains where the agency has strong strategic and capability fit; manage portfolio allocation."@en ;
    skos:broader aiu:BG_1 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_1_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Business model design and economics"@en ;
    skos:definition "Design viable value propositions, sustainable cost structures, and aligned revenue or funding models."@en ;
    skos:broader aiu:BG_1 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_1_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Strategic planning and scaling under uncertainty"@en ;
    skos:definition "Build plans that incorporate uncertainty and real options; scale initiatives at a pace matching organizational capability."@en ;
    skos:broader aiu:BG_1 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 2: Market, Customer, and Revenue Goals

aiu:BG_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Market, Customer, and Revenue Goals"@en ;
    skos:definition "Goals related to brand positioning, market understanding, customer acquisition, and customer experience."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_2_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Brand positioning, identity, and value communication"@en ;
    skos:definition "Articulate a distinctive brand positioning and communicate value to defined target audiences."@en ;
    skos:broader aiu:BG_2 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_2_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Market understanding, demand estimation, and segmentation"@en ;
    skos:definition "Define markets realistically based on behavior; develop evidence-based segmentation and demand forecasting."@en ;
    skos:broader aiu:BG_2 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_2_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Customer acquisition, conversion, and go-to-market"@en ;
    skos:definition "Clarify ideal beneficiary profiles; design outreach channels; improve enrollment and conversion."@en ;
    skos:broader aiu:BG_2 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_2_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Customer experience, satisfaction, and retention"@en ;
    skos:definition "Deliver low-friction, reliable service journeys; build responsive support; personalize using customer data."@en ;
    skos:broader aiu:BG_2 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 3: Product, Service, and Innovation Goals

aiu:BG_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Product, Service, and Innovation Goals"@en ;
    skos:definition "Goals related to product-market fit, quality, innovation pace, and portfolio lifecycle management."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_3_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Product-market fit and offer configuration"@en ;
    skos:definition "Validate demand and problem-solution fit with evidence before scaling; align pricing with value perception."@en ;
    skos:broader aiu:BG_3 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_3_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Quality, reliability, and consistency"@en ;
    skos:definition "Ensure products and services reliably perform as intended and deliver consistent experiences across channels."@en ;
    skos:broader aiu:BG_3 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_3_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Innovation pace and responsiveness"@en ;
    skos:definition "Maintain innovation cycles that keep pace with technology, competitors, and mission needs; invest in R&D."@en ;
    skos:broader aiu:BG_3 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_3_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Product portfolio and lifecycle management"@en ;
    skos:definition "Actively manage the portfolio including timely retirement of legacy programs; allocate resources by strategic fit."@en ;
    skos:broader aiu:BG_3 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 4: Operational and Process Goals

aiu:BG_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Operational and Process Goals"@en ;
    skos:definition "Goals related to process efficiency, supply chain, internal controls, and scaling operations."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_4_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Process efficiency and waste reduction"@en ;
    skos:definition "Minimize waste, relieve bottlenecks, standardize work, and improve process visibility and throughput."@en ;
    skos:broader aiu:BG_4 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_4_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Supply chain, logistics, inventory, and fulfillment"@en ;
    skos:definition "Strengthen upstream operations, improve logistics reliability, and optimize inventory levels."@en ;
    skos:broader aiu:BG_4 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_4_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Internal controls, procedures, and performance management"@en ;
    skos:definition "Establish robust internal controls and feedback loops to continuously improve compliant operations."@en ;
    skos:broader aiu:BG_4 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_4_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Scaling operations without degrading quality or CX"@en ;
    skos:definition "Scale volumes and complexity while maintaining quality and customer experience."@en ;
    skos:broader aiu:BG_4 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 5: Financial Structure and Performance Goals

aiu:BG_5 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Financial Structure and Performance Goals"@en ;
    skos:definition "Goals related to revenue stability, cost structure, profitability, and financial risk management."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_5_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Revenue stability, cash flow, and liquidity"@en ;
    skos:definition "Reduce revenue volatility; improve cash-flow forecasting and maintain adequate buffers."@en ;
    skos:broader aiu:BG_5 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_5_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Cost structure and inflation resilience"@en ;
    skos:definition "Optimize fixed vs. variable costs; enhance cost visibility; absorb inflation and input-cost shocks."@en ;
    skos:broader aiu:BG_5 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_5_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Profitability, ROI, and capital allocation"@en ;
    skos:definition "Strengthen margins; allocate capital to projects with superior risk-adjusted returns; conduct post-investment reviews."@en ;
    skos:broader aiu:BG_5 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_5_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Leverage, market risk, and financial risk management"@en ;
    skos:definition "Maintain leverage at resilient levels; manage interest-rate and market risks proactively."@en ;
    skos:broader aiu:BG_5 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 6: Human Capital, Culture, and Organizational Goals

aiu:BG_6 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Human Capital, Culture, and Organizational Goals"@en ;
    skos:definition "Goals related to talent strategy, engagement, retention, and organizational design."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_6_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Talent, skills, and workforce strategy"@en ;
    skos:definition "Align workforce skills and roles with strategic needs; invest in upskilling, reskilling, and internal mobility."@en ;
    skos:broader aiu:BG_6 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_6_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Engagement, culture, and incentives"@en ;
    skos:definition "Increase employee engagement; build healthy inclusive cultures; align incentives with long-term value."@en ;
    skos:broader aiu:BG_6 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_6_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Retention, burnout, and leadership pipelines"@en ;
    skos:definition "Reduce avoidable turnover; prevent burnout; build robust leadership pipelines and succession plans."@en ;
    skos:broader aiu:BG_6 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_6_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Organizational design and decision rights"@en ;
    skos:definition "Align structure with strategy; clarify roles and handoffs; design clear decision rights and governance."@en ;
    skos:broader aiu:BG_6 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 7: Governance, Legal, and Compliance Goals

aiu:BG_7 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Governance, Legal, and Compliance Goals"@en ;
    skos:definition "Goals related to regulatory compliance, governance structures, contract management, and ethics."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_7_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Regulatory and legal compliance"@en ;
    skos:definition "Achieve and maintain compliance with applicable regulations; minimize exposure to fines and sanctions."@en ;
    skos:broader aiu:BG_7 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_7_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Governance structures and board effectiveness"@en ;
    skos:definition "Ensure oversight bodies effectively oversee risk, safety, culture, and ethics."@en ;
    skos:broader aiu:BG_7 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_7_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Contract management and intellectual-property stewardship"@en ;
    skos:definition "Improve contract lifecycle management; protect and enforce intellectual property rights."@en ;
    skos:broader aiu:BG_7 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_7_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Ethics, fraud, and whistleblowing"@en ;
    skos:definition "Build effective ethics programs; strengthen anti-fraud controls; provide trusted whistleblower channels."@en ;
    skos:broader aiu:BG_7 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 8: Technology, Data, and Cybersecurity Goals

aiu:BG_8 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Technology, Data, and Cybersecurity Goals"@en ;
    skos:definition "Goals related to technology-data alignment, cybersecurity, and AI/automation enablement."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_8_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Technology and data alignment"@en ;
    skos:definition "Align technology and data strategy with mission priorities; modernize legacy systems; ensure data quality."@en ;
    skos:broader aiu:BG_8 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_8_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Cybersecurity and protection"@en ;
    skos:definition "Strengthen cybersecurity to protect assets, data, and operations; detect and respond quickly to threats."@en ;
    skos:broader aiu:BG_8 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_8_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Automation and AI enablement"@en ;
    skos:definition "Leverage automation and AI to enhance productivity, augment analysts, and manage associated risks."@en ;
    skos:broader aiu:BG_8 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 9: External Environment and Macroeconomic Goals

aiu:BG_9 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "External Environment and Macroeconomic Goals"@en ;
    skos:definition "Goals related to macroeconomic resilience, regulatory adaptability, and disaster or geopolitical risk."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_9_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Macroeconomic resilience"@en ;
    skos:definition "Build financial and operational resilience to downturns, inflation, and capital-access risks."@en ;
    skos:broader aiu:BG_9 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_9_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Regulatory and policy adaptability"@en ;
    skos:definition "Anticipate and adapt to tax, trade, and regulatory changes; protect access to contracts amid policy shifts."@en ;
    skos:broader aiu:BG_9 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_9_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Resilience to geopolitical, pandemic, and disaster shocks"@en ;
    skos:definition "Increase resilience to geopolitical conflict, pandemics, natural disasters, and energy supply shocks."@en ;
    skos:broader aiu:BG_9 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_9_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Labor, demographic, and social shifts"@en ;
    skos:definition "Adapt workforce strategies to demographic changes; reduce barriers to workforce participation."@en ;
    skos:broader aiu:BG_9 ; skos:inScheme aiu:BusinessGoalTaxonomy .

### Cluster 10: Reputation, Brand, and Stakeholder Trust Goals

aiu:BG_10 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Reputation, Brand, and Stakeholder Trust Goals"@en ;
    skos:definition "Goals related to product safety, ethical conduct, crisis readiness, and stakeholder alignment."@en ;
    skos:topConceptOf aiu:BusinessGoalTaxonomy ;
    skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_10_1 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Product safety, data protection, and incident prevention"@en ;
    skos:definition "Deliver safe products; protect personal data; prevent safety and environmental incidents."@en ;
    skos:broader aiu:BG_10 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_10_2 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Ethical conduct, compliance, and leadership integrity"@en ;
    skos:definition "Uphold high ethical standards; avoid fraud and misconduct; ensure leaders embody stated values."@en ;
    skos:broader aiu:BG_10 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_10_3 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Crisis readiness and communications"@en ;
    skos:definition "Respond quickly, transparently, and empathetically to crises; coordinate communications to avoid confusion."@en ;
    skos:broader aiu:BG_10 ; skos:inScheme aiu:BusinessGoalTaxonomy .

aiu:BG_10_4 a skos:Concept, owl:NamedIndividual, aiu:BusinessGoalConcept ;
    skos:prefLabel "Alignment with stakeholder expectations and social impact"@en ;
    skos:definition "Align actions with sustainability, diversity, and social responsibility commitments; demonstrate say-do consistency."@en ;
    skos:broader aiu:BG_10 ; skos:inScheme aiu:BusinessGoalTaxonomy .


