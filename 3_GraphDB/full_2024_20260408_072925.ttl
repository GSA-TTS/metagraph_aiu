aiu:plan_2024_NCUA_2123 a aiu:AIUseCasePlan ;
    aiu:hasBusinessGoal aiu:BG_3_2,  # Quality, reliability, and consistency
        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "Creates WCAG AA compliant color combinations. Tool that helps check or create brand colors for usability, contrast, and harmony."^^xsd:string .

aiu:plan_2024_NCUA_2124 a aiu:AIUseCasePlan ;
