    aiu:outputsText "The AI in this use case predicts whether a link on a webpage leads to a staff directory and extracts person names and teacher titles from webpage text."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII true .

aiu:proc_2024_DOC_189 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_DOC_189_acq ;
    aiu:hasDataDocLevel aiu:DDL_Partial ;
    aiu:hasDevelopmentMethod aiu:DM_Both ;
    aiu:hasDevelopmentStage aiu:DS_AcqDev ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DOC_189_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The Person-Place Model (PPM) in the Demographic Frame outputs predicted probabilities indicating the likelihood that a person resides at a specific address. These predictions are generated by a machine learning model that analyzes historical and current data to produce a probability score for each person-address record. These scores do not constitute a final decision or assignment; instead, they provide a flexible basis for determining residential locations based on the desired level of confidence or specific application needs. This output can be used as input to downstream processes, providing robust, data-driven estimates to support various Census Bureau use cases and enhance the accuracy of demographic analyses."^^xsd:string ;
    aiu:usesDemographicFeature aiu:DF_Age .

aiu:proc_2024_DOC_190 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_DOC_190_acq ;
