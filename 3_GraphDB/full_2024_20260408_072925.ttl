    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The model estimates the overall clinical readiness of inpatient patients using fundamental parameters including vital signs and lab result trends and then produces an output that aggregates the total anticipated number of patients across the facility that would be expected to be ready for discharge within 24 hours based on basic clinical criteria."^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:supportsHISP aiu:HISP_VHA ;
    aiu:usesPII true .

