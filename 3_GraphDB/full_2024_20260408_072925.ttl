aiu:proc_2024_HHS_610 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_610_acq ;
    aiu:hasDataDocLevel aiu:DDL_Partial ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_AcqDev ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_610_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText """The Design Your Facility tool uses large language models (LLMs) to transform building layout information shared by users in a conversational manner into data about buildings, rooms, and bed layers within the Unaccompanied Children (UC) Bed Network tooling.

The AI model suggests object configurations that should be applied to correctly model a facilitys digital twin of the building, room, and bed layout. The workflow relies solely on user descriptions and user confirmations."""^^xsd:string .

aiu:proc_2024_HHS_611 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_611_acq ;
    aiu:hasDataDocLevel aiu:DDL_Complete ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_AcqDev ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_611_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "A large-language model helps compile an aggregated report of costs by intaking a specific Congressional Appropriation Number (CAN), category, sub-CAN line item descriptions (which are not standardized), and a projection cost from the user (either by a CSV or manual entry)."^^xsd:string .

aiu:proc_2024_HHS_612 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_612_acq ;
    aiu:hasDataDocLevel aiu:DDL_WidelyAvailable ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_AcqDev ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_612_init ;
    aiu:hasInternalReviewLevel aiu:IR_Developed ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "As part of this project, we are conducting exploratory analyses including supervised and unsupervised AI techniques to determine whether the data we have on grant spend over time can power a predictive model that reasonably identifies grants with a higher likelihood of under-utilizing funds."^^xsd:string .

aiu:proc_2024_HHS_613 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_613_acq ;
    aiu:hasDataDocLevel aiu:DDL_Partial ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_AcqDev ;
    aiu:hasImpactType aiu:IT_Safety ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_613_init ;
    aiu:hasInternalReviewLevel aiu:IR_Developed ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "Creates a structured data asset of  the critical data points needed about a separation case. AI will be used to conduct initial parsing of the data provided by CBP and highlight whether or not the required fields from the Ms L vs. ICE settlement are included and can therefore be updated into the child's profile in ORR's data system.  ORR's Intakes Team does final review and in cases where data appears to be missing, the ORR Intakes Team reaches back out to CBP for that information."^^xsd:string .

aiu:proc_2024_HHS_614 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_614_acq ;
    aiu:hasDataDocLevel aiu:DDL_Partial ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_AcqDev ;
    aiu:hasImpactType aiu:IT_Safety ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_614_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_GovServices ;
    aiu:outputsText """In the NOC triage system, AI will be used for two purposes:

1. We will use AI to parse the NOCs to generate structured fields from the text and validate categorizations.

2. AI will provide prioritization recommendations -- but not make decisions -- on the most critical NOCs for the ORR team to review first."""^^xsd:string .

aiu:proc_2024_HHS_615 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_615_acq ;
    aiu:hasDataDocLevel aiu:DDL_Complete ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_AcqDev ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_615_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The UC Program Policy & Procedure Research Tool speeds up research of relevant laws, standards, policies, and procedures content curated and approved by ORR's policy team. This research is one part of the process that informs ORR's monitoring team's decisions on whether corrective actions are needed and if so, what corrective actions. AI is not used to suggest corrective actions but rather support determination of whether care providers are in compliance."^^xsd:string .

aiu:proc_2024_HHS_616 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_616_init ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "ORR is exploring use of process digital twins to provide the ability to run \"what if\" scenarios"^^xsd:string .

aiu:proc_2024_HHS_617 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Retired ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasRetirementTime aiu:ti_proc_2024_HHS_617_ret ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "A large language model (LLM) was used to tag public comments by: topics selected primarily by policy experts; sentiment; and intent (e.g. question, suggestion) alongside first drafts of topic-based summaries."^^xsd:string .

aiu:proc_2024_HHS_618 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Retired ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasRetirementTime aiu:ti_proc_2024_HHS_618_ret ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "An AI-enabled search tool was used to research likely organization name, purpose, and policy space based on the domains (e.g. \"@organization.com\")  from contact email addresses."^^xsd:string .

