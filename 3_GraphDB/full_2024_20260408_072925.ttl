    aiu:hasInternalReviewLevel aiu:IR_Developed ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The system primarily outputs predictions that can then (optionally) be summarized and communicated as recommendations."^^xsd:string ;
    aiu:saopReviewed false ;
