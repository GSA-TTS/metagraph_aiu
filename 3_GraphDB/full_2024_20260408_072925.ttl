    aiu:hasTopicArea aiu:TA_Transportation ;
    aiu:outputsText "AI system outputs multiple decisions to include screening location performance, rates and standards of the end-to-end screening system, and passenger wait times."^^xsd:string .

aiu:proc_2024_DHS_139 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_DHS_139_acq ;
    aiu:hasDataDocLevel aiu:DDL_Complete ;
    aiu:hasDevelopmentMethod aiu:DM_Both ;
