    aiu:usesPII false .

aiu:proc_2024_DHS_56 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_DHS_56_acq ;
    aiu:hasCodeAccess aiu:CA_NoAccess ;
    aiu:hasDataDocLevel aiu:DDL_Partial ;
