    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_676_init ;
    aiu:hasInternalReviewLevel aiu:IR_Published ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "This chatbot, powered by Azure OpenAI Large Language Models, will generate responses to questions asked by the user. The chatbot's output can then be copied and pasted or manually entered into the appropriate testing process by the staff to ensure any code used from the chatbot's output meets the criteria of the current task. The output must be copied and pasted or manually entered somewhere for the output to be used by staff."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_677 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_677_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_WidelyAvailable ;
    aiu:hasDevelopmentMethod aiu:DM_Both ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_677_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_677_init ;
    aiu:hasInternalReviewLevel aiu:IR_Published ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "This chatbot, powered by Azure OpenAI Large Language Models, will generate responses to questions asked by the user, in this case about either some software code, software code documentation, code concepts, or to help generate software code. The chatbot's output can then be copied and pasted or manually entered into the appropriate testing process by the staff to ensure any code used from the chatbot's output meets the criteria of the current task."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_678 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_678_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_WidelyAvailable ;
    aiu:hasDevelopmentMethod aiu:DM_Both ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_678_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_678_init ;
    aiu:hasInternalReviewLevel aiu:IR_Published ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "This chatbot, powered by Azure OpenAI Large Language Models, will generate responses to questions asked by the user, in this case a summary of a larger document. The chatbot's output can then be copied and pasted or manually entered into the appropriate testing process by the staff to ensure any code used from the chatbot's output meets the criteria of the current task."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_679 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_679_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_Partial ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_679_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_679_init ;
    aiu:hasInternalReviewLevel aiu:IR_Published ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The Artificial Intelligence Platform (AIP) available within SEDRIC provides CDC epidemiologists the power to accelerate their investigations of multi-state foodborne disease outbreaks. Using the information previously extracted from receipts and other records, AIP can summarize these results to provide insights from information pulled from shopper receipts. Given ingredients can be found in multiple food products, and some ingredients such as herbs like coriander/cilantro may go by multiple names or be reported in multiple languages, this summarization tool provides a faster way to gather summary information from receipts on different food items which may be part of a foodborne investigation."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_680 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_680_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_Partial ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_680_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_680_init ;
    aiu:hasInternalReviewLevel aiu:IR_Published ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "Palantirs Artificial Intelligence Platform (AIP) available within SEDRIC provides CDC epidemiologists the power to accelerate their investigations of multi-state foodborne disease outbreaks. It can extract structured data from grocery receipts, shopper card records, and free-text responses in order to catalog the food items purchased by affected patients. It can also map those items to SEDRIC-defined vehicles which categorize the items and highlight commonalities across patients, helping to pinpoint potential outbreak vehicles."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_681 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_681_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_Missing ;
    aiu:hasDevelopmentMethod aiu:DM_InHouse ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_681_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_681_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "NLP and Food Vehicle Investigation Module (FVIM) uses language learning models and Text Classification Tools to identify potential vehicles. NLP tool uses text classification to provide probabilities that a food is associated with the outbreak based on reports in the SEDRIC line list. FVIM identifies past outbreak with similar key demographic and temporal characteristics to the selected outbreak to guide hypothesis generation. FVIM analyses reported food exposures uploaded to the SEDRIC line list and categorizes responses into food commodity types that are then compared to FoodNet Population survey results weighted by age, sex and ethnicity and generates a statistical comparison"^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII true .

aiu:proc_2024_HHS_682 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_682_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_WidelyAvailable ;
    aiu:hasDevelopmentMethod aiu:DM_InHouse ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_682_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_682_init ;
    aiu:hasInternalReviewLevel aiu:IR_Published ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The AI algorithm compares sets of haplotypes sequenced from a set of clinical samples and computes a set of genetic distances. It performs these comparisons across thousands of genotypes to identify infections that are closely related or unrelated. The resultant genetic distances are then clustered to define groups of closely related infections. This information is used routinely to complement epidemiologic investigations of cyclosporiasis (Cyclospora) outbreaks, and traceback investigations performed by state public health agencies and FDA. While this AI has mostly been applied to Cyclospora, we have also applied it to other parasites, including malaria, and certain parasitic worms."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

