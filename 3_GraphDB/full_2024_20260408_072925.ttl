    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "MedCoder assists with the identifying cause of death codes from death certificates using ICD-10 Underlying cause codes and automatically identifies and rejects complex causes of death as well as frequently miscoded ones, requiring manual coding or review. Additionally, in production, MedCoder utilizes natural language processing (NLP) to cleanse and standardize literal text cause of death statements before performing coding."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesDemographicFeature aiu:DF_Sex ;
    aiu:usesPII false .

