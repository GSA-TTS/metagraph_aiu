        aiu:BG_8_1,  # Technology and data alignment
        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "Automation of multiple manual processes and improvement of data quality and governance. Initially the system will use M.L. to identify  inconsistent data and make preditions of how that data should be organized."^^xsd:string .

aiu:plan_2024_DOE_251 a aiu:AIUseCasePlan ;
