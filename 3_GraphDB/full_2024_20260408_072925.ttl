    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "We are using LLMs to analyze the questions inputted by users. The AI model synthesizes the provided documentation sources and then summarizes and answers the users questions with cited sources."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_620 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent false ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_620_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_WidelyAvailable ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_620_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_620_init ;
    aiu:hasInternalReviewLevel aiu:IR_Developed ;
    aiu:hasTopicArea aiu:TA_GovServices ;
    aiu:outputsText "The Information Gateway hotline connects to a phone interactive voice response (IVR) managed by OneReach AI. OneReach maintains a database of state hotlines for reporting child abuse and neglect that it can connect a caller to based on their inbound phone area code. Additionally, OneReach offers a limited FAQ texting service that utilizes natural language processing to answer user queries. User queries are used for reinforcement training by a human AI trainer and to develop additional FAQs."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII true .

