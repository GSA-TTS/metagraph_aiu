aiu:plan_2024_VA_1635 a aiu:AIUseCasePlan ;
    aiu:hasBusinessGoal aiu:BG_10_1,  # Product safety, data protection, and incident prevention
        aiu:BG_3_2,  # Quality, reliability, and consistency
        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "This AI model's purpose is to screen Chest CT scans for coronary artery calcification and notify physicians of patients with increased cardiovascular risk. This will help physicians detect cardiovascular disease earlier and better treat their patients. The model will output a coronary artery calcium score and also output image masks showing physicians where the model detected coronary artery calcium on the patients chest images."^^xsd:string .

