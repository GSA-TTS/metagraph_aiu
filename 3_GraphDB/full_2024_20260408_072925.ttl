    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "Our methods entail the use of natural language processing (NLP) of progress note documentation of treatment within the PTSD Clinical Team (PCT) specialty care clinics, to identify SI mentions, to quantify SI assessment documentation, and to classify SI mention clinical quality. We will provide reports of consistency and quality and the national, VISN, and medical center levels."^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:usesPII true .

