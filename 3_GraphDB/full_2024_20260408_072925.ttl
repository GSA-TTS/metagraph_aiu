    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_GovServices ;
    aiu:outputsText "The output is sets of citation records that are classified as relevant to biomedicine and the life sciences. Automation of article selection allows NLM to more efficiently and effectively index and host relevant information for the public."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

