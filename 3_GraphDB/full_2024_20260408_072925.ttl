    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The system creates a layer which is overlaid over the image to produce a box around items of interest it has determined to be likely human beings."^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:usesPII false .

