    aiu:partOfInventory aiu:inv2024 ;
    aiu:useCaseName "SERVIR Water Security: SERVIR is applying deep learning on in situ and global/regional hydrologic forecasts to fill gaps in historic and recent streamflow and river elevation estimates, and improve streamflow forecasts, to a vertical precision of meters to centimeters, potentially for thousands to millions or river reaches worldwide."^^xsd:string .

aiu:ucr_2024_USAID_1098 a aiu:UseCaseRecord ;
    aiu:describesPlan aiu:plan_2024_USAID_1098 ;
