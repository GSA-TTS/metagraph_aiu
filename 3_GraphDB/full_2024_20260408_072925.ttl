aiu:proc_2024_HHS_628 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_628_init ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "This AI use case will involve training an artificial intelligence system to examine the background of peer reviewers - taking into account factors such as expertise, race/ethnicity, gender, and geographic area - and match these inputs to the relevant study section, subsequently referring the reviewer to the Scientific Review Officer (SRO). This flexible system will empower SROs to make the final recruitment decision or to refer the expert to another study section or Special Emphasis Panel (SEP)."^^xsd:string .

aiu:proc_2024_HHS_629 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_629_init ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "Provide capability to allow user to type a question in common language and instantly get a response . Answers come in the form of automatic data visualizations, with no need to manually drag-and-drop fields or understand the nuances of user's datas structure."^^xsd:string .

aiu:proc_2024_HHS_630 a aiu:AIUseCaseProcess ;
