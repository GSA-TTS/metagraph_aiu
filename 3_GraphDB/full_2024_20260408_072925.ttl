    aiu:hasInitiationTime aiu:ti_proc_2024_TREAS_1001_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The system will extract text from the forms (pdf's) translating handwritten text into a digital format. After the extraction process the system presents what was extracted to the end user to then validate before anything is sent to any downstream systems."^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:usesPII false .

