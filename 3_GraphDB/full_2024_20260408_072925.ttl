    aiu:hasTopicArea aiu:TA_GovServices ;
    aiu:outputsText "The classifier takes as input free-text related to a studys endpoint and returns a prediction of whether one or more issues is present."^^xsd:string .

aiu:proc_2024_HHS_810 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
