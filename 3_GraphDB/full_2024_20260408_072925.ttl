aiu:proc_2024_VA_1515 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_VA_1515_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_Partial ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Rights ;
    aiu:hasImplementationTime aiu:ti_proc_2024_VA_1515_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_VA_1515_init ;
    aiu:hasInternalReviewLevel aiu:IR_NoDocs ;
    aiu:hasTopicArea aiu:TA_GovServices ;
    aiu:outputsText "The following is high-level scenarios describe the inputs --->automated processes--->outputs:  Scenario A:  Claimant submits application for benefits via handwritten, typed, or VA.gov submission  --->  POI automation extracts data from forms and other documents submitted with application  --->  extracted data and existing Veteran/Beneficiary file data is processed in accordance with business rules to determine outcome of claim  --->  outputs are:  -updated Veteran/Beneficiary files, -completed Pension-related claim actions to include stop and start of awards (delivery of benefits), and -Notification Letters to Claimants.  Scenario B:  same as above, except, claim is established via computer matching agreement with other Government agencies (e.g. Social Security Administration) or other VBA-internal process rather than actually receiving an application from a claimant."^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:supportsHISP aiu:HISP_VBA ;
    aiu:usesPII true .

