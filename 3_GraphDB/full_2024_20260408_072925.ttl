        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "Citrix uses AI to optimize virtual desktops, manage workloads, and enhance security with behavioral analysis and threat detection. Citrix uses AI for optimizing virtual desktop performance, managing workloads, and enhancing security through behavioral analysis and threat detection."^^xsd:string .

