        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "Oracle Enterprise 23AI has built in AI for predictive analytics, AI Vector search, Natural Language queries and integration with Large Language Models Oracle Enterprise 23AI has built in AI for predictive analytics, AI Vector search, Natural Language queries and integration with Large Language Models"^^xsd:string .

