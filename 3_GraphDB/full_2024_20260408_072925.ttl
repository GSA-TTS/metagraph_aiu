aiu:proc_2024_HHS_798 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_798_acq ;
    aiu:hasCodeAccess aiu:CA_NoAccess ;
    aiu:hasDataDocLevel aiu:DDL_Missing ;
    aiu:hasDevelopmentMethod aiu:DM_InHouse ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_798_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_798_init ;
    aiu:hasInternalReviewLevel aiu:IR_NoDocs ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The Assisted Referral Tool (ART) recommends potentially appropriate study sections, based on the scientific content of a users grant application.  The user enters the application text and hits the Submit button to get a list of relevant study sections (scientific areas) in two groups, as Strong and Possible matches. The information provided to ART is only used to recommend study sections and is not stored or persisted.   The recommendations made by ART are solely for the benefit of the user."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_799 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Retired ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasRetirementTime aiu:ti_proc_2024_HHS_799_ret ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The input data consists of four 3-dimensional vectors obtained from an IMU attached to the participant's hand while they perform cognitive and motor tasks. The classification result from the deep learning model outputs a value of 0 or 1, indicating ASD or typical development, respectively."^^xsd:string .

