    aiu:hasInternalReviewLevel aiu:IR_Developed ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "As part of a broader effort to establish a TANF knowledge base on a unified platform, large language models were used to: 1) generate draft knowledge base article topics based on historical tracker information; and 2) categorize articles to help organize the knowledge base."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_624 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent false ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_624_acq ;
    aiu:hasCodeAccess aiu:CA_NoAccess ;
    aiu:hasDataDocLevel aiu:DDL_Complete ;
    aiu:hasDevelopmentMethod aiu:DM_InHouse ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_624_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_624_init ;
    aiu:hasInternalReviewLevel aiu:IR_Published ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "We use commercial off-the-shelf software that have built-in AI functionality to suggest topic tagging of qualitative data."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII true .

aiu:proc_2024_HHS_625 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_625_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_Missing ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_625_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_625_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "This AI use case aims to optimize search results by adjusting their ranking, ensuring that the most pertinent information is displayed at the top. It also enhances search effectiveness by adding synonyms to queries behind the scenes. It further improves user experience by auto-completing queries as they are being typed, and showing related searches that might offer additional valuable insights. The system also proposes content tags automatically, leveraging machine learning to assess existing content tagging patterns. Additionally, it suggests spelling corrections and reformats search queries based on data from Google Analytics."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_626 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_626_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
