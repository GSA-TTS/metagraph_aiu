aiu:proc_2024_VA_1628 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent false ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_VA_1628_acq ;
    aiu:hasCodeAccess aiu:CA_NoAccess ;
    aiu:hasDataDocLevel aiu:DDL_Missing ;
    aiu:hasDevelopmentMethod aiu:DM_InHouse ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_VA_1628_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_VA_1628_init ;
    aiu:hasInternalReviewLevel aiu:IR_NoDocs ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The outputs of this use of AI is a candidate list of terms related to a concept of interest.  This candidate list is combined with suggestions generated by human experts and then these are reviewed by a subject matter expert to generate a final list of terms for use in text-matching algorithms to extract medical record free text mentions of interest. For the pre-trained Large Language model approach, the input is a query prompting for synonyms of terms related to the concept of interest.  The output is the answer provided by the LLM, including the suggested candidate terms and the original terms that were stated in the query.  For the word and phrase embedding models, the input is an initial list of terms that are relevant to the concept of interest and the output are the suggested candidate terms, ranked by their statistical similarity to the original terms, based on the transformation of a clinical corpus into vector space or an embedding model.  Regardless of the type of model used, all suggested candidate terms are reviewed by subject matter experts to ensure quality term lists are used in all text searches."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

