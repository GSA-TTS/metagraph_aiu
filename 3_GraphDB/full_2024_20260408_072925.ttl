    aiu:useCaseName "SERVIR Agriculture and Food Security: SERVIR is using machine learning techniques to interpret satellite data to improve crop area, crop type, crop condition, and yield estimates at the scale of 10s of meters, aggregated to country, district, province, or country."^^xsd:string .

aiu:ucr_2024_USAID_1097 a aiu:UseCaseRecord ;
    aiu:describesPlan aiu:plan_2024_USAID_1097 ;
