    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_687_init ;
    aiu:hasInternalReviewLevel aiu:IR_NoDocs ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The RAM is a reporting tool within the National DPP Operations Center which already has an ATO. The RAM module ingests large amounts of organization-level data including National DPP participant enrollment records, demographics, and specific risk factors to perform supervised learning and model generation. This machine learning model is used to predict and quantitatively rank those organizations that are at highest risk of failing to meet program objectives. This information, both input and RAM output, is currently fully sequestered to associates of the National DPP of the CDC. In the future, with continued development and validation, the plan is to allow external-to-CDC State Quality Specialist (SQS) users access to the outputs of RAM for additional assistance with improving organization success."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_688 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_688_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_WidelyAvailable ;
    aiu:hasDevelopmentMethod aiu:DM_InHouse ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_688_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_688_init ;
    aiu:hasInternalReviewLevel aiu:IR_Published ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "CDC's National Center for Health Statistics (NCHS) has developed and released a model to detect nonresponses in open-text survey responses. This helps improve survey data quality and question and questionnaire design. The system is a natural language processing (NLP) model that has been fine-tuned on a custom dataset of survey responses."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII true .

aiu:proc_2024_HHS_689 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_689_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_WidelyAvailable ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_HHS_689_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_689_init ;
    aiu:hasInternalReviewLevel aiu:IR_Developed ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "CDC's National Center for Health Statistics (NCHS) Data Linkage Program has implemented both supervised and unsupervised machine learning (ML) techniques in their linkage algorithms. The Sequential Coverage Algorithm (SCA), a supervised ML algorithm, is used to develop joining methods (or blocking groups) when working with very large datasets. The unsupervised partial Expectation-Maximization (EM) estimation is used to estimate the proportion of pairs that are matches within each block. Both methods improve linkage accuracy and efficiency."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesDemographicFeature aiu:DF_Sex ;
    aiu:usesPII true .

