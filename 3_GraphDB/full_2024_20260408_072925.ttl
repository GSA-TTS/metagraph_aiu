    aiu:hasBusinessGoal aiu:BG_4_1,  # Process efficiency and waste reduction
        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "Fast radiative transfer calculations for increasing satellite data needed by weathers forecasts and the generation of satellite products. simulated satellite radiances and sensitivities (Jacobian) of satellite data"^^xsd:string .

