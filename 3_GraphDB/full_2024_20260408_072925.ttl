    aiu:hasBusinessGoal aiu:BG_8_1,  # Technology and data alignment
        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "Predictive analytics, automated indexing, and anomaly detection in data management and queries. SQL Server incorporates AI for predictive analytics, automated indexing, and anomaly detection in data management and queries."^^xsd:string .

