    aiu:usesPII false .

aiu:proc_2024_DHS_127 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_DHS_127_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_Complete ;
    aiu:hasDevelopmentMethod aiu:DM_Both ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_DHS_127_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_127_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText """Behavioral Baseline Modeling: Develop a baseline for each individual based on regular access patterns, network usage, and interactions with classified data or secure areas.
Anomaly Detection: Employ machine learning models to detect deviations from established baselines, such as unusual access times, atypical access to high-sensitivity resources, or excessive data downloads.
Risk Scoring: Assign a risk score to each user based on observed anomalies, factoring in historical behavior, job role, and access level, allowing security teams to prioritize investigations.
Automated Alerts & Reporting: Generate automated alerts for high-risk behaviors or patterns of concern and deliver timely reports to personnel security teams for further investigation.\""""^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:usesPII true .

aiu:proc_2024_DHS_128 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_DHS_128_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_WidelyAvailable ;
    aiu:hasDevelopmentMethod aiu:DM_InHouse ;
    aiu:hasDevelopmentStage aiu:DS_OpsMaint ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasImplementationTime aiu:ti_proc_2024_DHS_128_impl ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_128_init ;
    aiu:hasInternalReviewLevel aiu:IR_NoDocs ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The systems outputs include a set of topics inferred or surfaced from the raw text comment data, as well as sentiments or other classifications inferred from the data."^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:usesPII false .

aiu:proc_2024_DHS_129 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_129_init ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The main AI system outputs will include anomaly detection for emerging trends in clinical record patterns. AI/ML outputs will also be used to find these clinical patterns by clustering, classification and topic modeling. These clinical patterns will finally be output as linear reference models that are simple enough to be interpreted and guided by human clinicians using human-in-the-loop collaboration."^^xsd:string .

aiu:proc_2024_DHS_13 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_13_init ;
    aiu:hasTopicArea aiu:TA_GovServices ;
    aiu:outputsText "The AI-chatbot will provide natural language responses to user queries."^^xsd:string .

aiu:proc_2024_DHS_130 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_130_init ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The main AI system output will be anomaly detection which represents two elements: 1) AI/ML predictions for usual trends in news story key terms vs. 2) the actual daily number of mentions for key terms in the news. When the actual number of mentions for key terms exceeds modeled predictions, these will be detected as anomalies."^^xsd:string .

aiu:proc_2024_DHS_131 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_131_init ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The main AI system output will be the translation of online information into a structured, machine-readable dataset. This includes language translation for non-English articles, labeling articles by health threat types, and ranking articles by relevance to health threats. This dataset will then be used to create the wholistic visuals in Canvas and Dashboard."^^xsd:string .

