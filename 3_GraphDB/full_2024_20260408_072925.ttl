    aiu:hasBusinessGoal aiu:BG_4_1,  # Process efficiency and waste reduction
        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "To help foster smart recommendations, data insights, and enhanced collaboration. Microsoft 365 suite (Teams, SharePoint, Excel, PowerPoint, Word) uses AI for various functionalities like language translation, smart recommendations, data insights, and enhanced collaboration."^^xsd:string .

aiu:plan_2024_FHFA_1365 a aiu:AIUseCasePlan ;
