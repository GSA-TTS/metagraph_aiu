    aiu:hasInternalReviewLevel aiu:IR_NoDocs ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "Currently it is a list of potential anomalies or outliers within the system, but development is still ongoing."^^xsd:string .

aiu:proc_2024_DHS_142 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Both ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_142_init ;
    aiu:hasTopicArea aiu:TA_Transportation ;
    aiu:outputsText "Images that mimic the human body and various threats."^^xsd:string .

aiu:proc_2024_DHS_143 a aiu:AIUseCaseProcess ;
    aiu:hasDevelopmentStage aiu:DS_Initiated ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_143_init ;
    aiu:hasTopicArea aiu:TA_Transportation ;
    aiu:outputsText "The AI system initiates an AIT scan when the passenger is in the optimum position. Depending on the results of the AIT scan, the passenger would be routed either for additional screening or to the re-composure area to claim their accessible property and transit into the sterile area."^^xsd:string .

