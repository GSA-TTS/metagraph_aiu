aiu:proc_2024_HHS_623 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_623_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
