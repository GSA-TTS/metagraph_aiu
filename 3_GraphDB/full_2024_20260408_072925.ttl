    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_GovServices ;
    aiu:outputsText "This AI technique leverages the intelligence of our users and cutting-edge machine-learning technology as an alternative to the traditional date-sort order that appears in many traditional search engines. Trained with past user searches with dozens of relevance-ranking factors, the Best Match algorithm demonstrates state-of-the-art retrieval performance and an improved user experience."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_806 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_806_acq ;
