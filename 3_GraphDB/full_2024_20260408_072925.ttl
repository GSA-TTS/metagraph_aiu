    aiu:hasBusinessGoal aiu:BG_2_4,  # Customer experience, satisfaction, and retention
        aiu:BG_8_3 ;  # Automation and AI enablement
    aiu:purposeBenefitsText "Assisting the public in finding information on the FAA website. We are using our AI Chat Bot to better inform the public. In our efforts to engage with the public we wanted to use this tool to direct the public to the tremendous amount of information that is on the FAA Website."^^xsd:string .

