    aiu:outputsText "The AI will use description of data sets that come from both NIH and federal data catalogs.  This will be periodically updated.  As output, the AI will provide rank order listings of recommended data sets."^^xsd:string .

aiu:proc_2024_HHS_808 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_808_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
    aiu:hasDataDocLevel aiu:DDL_Complete ;
    aiu:hasDevelopmentMethod aiu:DM_InHouse ;
    aiu:hasDevelopmentStage aiu:DS_ImplAssess ;
    aiu:hasImpactType aiu:IT_Neither ;
    aiu:hasInitiationTime aiu:ti_proc_2024_HHS_808_init ;
    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_GovServices ;
    aiu:outputsText "The Clinical Trial Predictor uses an ensemble of several NLP and ML algorithms to predict whether applications may involve clinical trials based on the text of their titles, abstracts, narratives, specific aims, and research strategies. The responses are only used to make extramural officers aware of the fact that an application submitted to a NOFO that doesn't allow clinical trials may contain a clinical trial.  The extramural officers then evaluate the identified applications for the presence of a clinical trial.  No decisions are made by the AI, nor is the AI output used as the principle basis of a decision; it is just used to help the extramural officers identify applications containing clinical trials more quickly."^^xsd:string ;
    aiu:saopReviewed false ;
    aiu:usesPII false .

aiu:proc_2024_HHS_809 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_HHS_809_acq ;
