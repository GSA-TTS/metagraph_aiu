    aiu:usesPII false .

aiu:proc_2024_TREAS_1019 a aiu:AIUseCaseProcess ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_TREAS_1019_acq ;
    aiu:hasDataDocLevel aiu:DDL_Complete ;
    aiu:hasDevelopmentMethod aiu:DM_Contracting ;
