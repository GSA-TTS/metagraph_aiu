    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The output is email data that has undergone spam message classification, translation, and entity extraction, including names, organizations, or locations."^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:usesPII true .

