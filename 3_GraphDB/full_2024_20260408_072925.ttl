    aiu:hasInternalReviewLevel aiu:IR_Limited ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "The output is a dataset of structured identification data."^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:usesPII true .

aiu:proc_2024_DHS_117 a aiu:AIUseCaseProcess ;
    aiu:customCodePresent true ;
    aiu:hasAcqDevTime aiu:ti_proc_2024_DHS_117_acq ;
    aiu:hasCodeAccess aiu:CA_PrivateSource ;
