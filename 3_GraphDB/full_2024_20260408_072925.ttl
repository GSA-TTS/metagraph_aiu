    aiu:hasInitiationTime aiu:ti_proc_2024_DHS_173_init ;
    aiu:hasInternalReviewLevel aiu:IR_Developed ;
    aiu:hasTopicArea aiu:TA_MissionEnabling ;
    aiu:outputsText "Numerical Fingerprint Quality score, which is compared against  fingerprint quality thresholds (per finger and per set of fingerprints) to align with FBI specifications"^^xsd:string ;
    aiu:saopReviewed true ;
    aiu:usesPII true .

